import os
import requests
from PIL import Image

UNITYSVC_API_KEY = os.getenv("UNITYSVC_API_KEY")
SERVICE_BASE_URL = "{{ service_base_url }}"

url = f"{SERVICE_BASE_URL}/models/{{offering.name}}"

headers = {
    "Authorization": f"Bearer {UNITYSVC_API_KEY}"
}

# Generate a test input image if not present
if not os.path.exists("input.png"):
    Image.new("RGB", (64, 64), color="red").save("input.png")

with open("input.png", "rb") as img:
    response = requests.post(
        url,
        headers=headers,
        files={"image": img},
        data={
            "prompt": "Turn this into a cinematic cyberpunk scene",
            "strength": 0.6
        }
    )

response.raise_for_status()

with open("output.png", "wb") as f:
    f.write(response.content)

print("Saved output.png")
