import os
import struct
import time
import wave
import requests

UNITYSVC_API_KEY = os.getenv("UNITYSVC_API_KEY")
SERVICE_BASE_URL = "{{ service_base_url }}"

def transcribe_audio(
    model_id: str,
    audio_path: str,
    retries: int = 5
):
    url = f"https://router.huggingface.co/models/{{offering.name}}"

    headers = {
        "Authorization": f"Bearer {UNITYSVC_API_KEY}"
    }

    for _ in range(retries):
        with open(audio_path, "rb") as audio:
            response = requests.post(
                url,
                headers=headers,
                files={"file": audio}
            )

        if response.status_code == 503:
            time.sleep(2)
            continue

        response.raise_for_status()
        return response.json()["text"]

    raise RuntimeError("ASR model not ready.")


# ===== Example usage =====
if __name__ == "__main__":
    # Generate a test audio file if not present (1 second of silence)
    if not os.path.exists("audio.wav"):
        with wave.open("audio.wav", "w") as f:
            f.setnchannels(1)
            f.setsampwidth(2)
            f.setframerate(16000)
            f.writeframes(struct.pack("<h", 0) * 16000)

    text = transcribe_audio(
        model_id="{{ routing_key.model }}",
        audio_path="audio.wav"
    )
    print(text)
