# Generate a test input image if not present
[ -f input.png ] || python3 -c "from PIL import Image; Image.new('RGB',(64,64),color='red').save('input.png')"

curl -X POST \
  -H "Authorization: Bearer $UNITYSVC_API_KEY" \
  -F "image=@input.png" \
  -F 'prompt=Turn this into a cinematic cyberpunk scene' \
  -F 'strength=0.6' \
  ${SERVICE_BASE_URL}/models/{{offering.name}} \
  --output output.png
