import os
import requests

API_KEY = os.getenv("API_KEY")

functions = [
    {
        "name": "count_gs",
        "description": "Count the number of times the letter G appears.",
        "parameters": {
            "type": "object",
            "properties": {
                "input_text": {"type": "string"}
            },
            "required": ["input_text"],
        },
    }
]

response = requests.post(
    "https://router.huggingface.co/v1/chat/completions",
    headers={"Authorization": f"Bearer {API_KEY}"},
    json={
        "model": "{{offering.name}}",
        "messages": [
            {"role": "user", "content": "Count the Gs in huggingface."}
        ],
        "functions": functions,
        "function_call": {"name": "count_gs"}
    },
)

print(response.json())
