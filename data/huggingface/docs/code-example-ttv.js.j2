import fs from "fs";

const API_KEY = process.env.API_KEY;

const response = await fetch(
  `https://router.huggingface.co/models/{{offering.name}}`,
  {
    method: "POST",
    headers: {
      "Authorization": `Bearer ${API_KEY}`,
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
      inputs: "A cinematic shot of a futuristic city at sunset, flying drones"
    })
  }
);

if (!response.ok) {
  throw new Error(await response.text());
}

const videoBuffer = await response.arrayBuffer();
fs.writeFileSync("output.mp4", Buffer.from(videoBuffer));

console.log("Saved output.mp4");
