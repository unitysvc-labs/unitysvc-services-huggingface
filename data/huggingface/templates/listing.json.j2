{#- Select code example templates based on model capabilities (HuggingFace pipeline_tag) -#}
{%- if "automatic-speech-recognition" in capabilities -%}
  {%- set ex = "-prerecordedtranscription" -%}
{%- elif "text-to-speech" in capabilities or "text-to-audio" in capabilities -%}
  {%- set ex = "-tts" -%}
{%- elif "text-to-video" in capabilities or "image-to-video" in capabilities -%}
  {%- set ex = "-ttv" -%}
{%- elif "image-to-image" in capabilities -%}
  {%- set ex = "-imagetoimage" -%}
{%- elif "text-to-image" in capabilities or "unconditional-image-generation" in capabilities -%}
  {%- set ex = "-image" -%}
{%- elif "feature-extraction" in capabilities or "sentence-similarity" in capabilities -%}
  {%- set ex = "-sentencetransformers" -%}
{%- elif "guard" in (capabilities | join(" ")) -%}
  {%- set ex = "-guard" -%}
{%- else -%}
  {%- set ex = "" -%}
{%- endif -%}

{
  "schema": "listing_v1",
  "status": "{{ status | default('ready') }}",
  "currency": "USD",
{%- if list_price %}
  "list_price": {{ list_price | tojson }},
{%- endif %}

  "user_access_interfaces": {
    "provider_api": {
      "access_method": "http",
      "base_url": "${API_GATEWAY_BASE_URL}/p/{{ provider_name }}",
      "routing_key": {
        "model": "{{ offering_name }}"
      }
    }
  },

  "documents": {

    "How to use this model": {
      "category": "getting_started",
      "file_path": "../../docs/description.md",
      "is_active": true,
      "is_public": true,
      "mime_type": "markdown"
    },

    "Python code example": {
      "category": "code_example",
      "description": "Example code to use the model",
      "file_path": "../../docs/code-example{{ ex }}.py.j2",
      "is_active": true,
      "is_public": true,
      "mime_type": "python"
    },

    "Python function calling code example": {
      "category": "code_example",
      "description": "Example code to use the model",
      "file_path": "../../docs/code-example{{ ex }}-fc.py.j2",
      "is_active": true,
      "is_public": true,
      "mime_type": "python"
    },

    "JavaScript code example": {
      "category": "code_example",
      "description": "Example code to use the model",
      "file_path": "../../docs/code-example{{ ex }}.js.j2",
      "is_active": true,
      "is_public": true,
      "mime_type": "javascript"
    },

    "cURL code example": {
      "category": "code_example",
      "description": "Example code to use the model",
      "file_path": "../../docs/code-example{{ ex }}.sh.j2",
      "is_active": true,
      "is_public": true,
      "mime_type": "bash"
    },

    "Connectivity test": {
      "category": "connectivity_test",
      "description": "Connectivity test",
      "file_path": "../../docs/connectivity.sh.j2",
      "is_active": true,
      "is_public": false,
      "mime_type": "bash"
    },
    "Default request body": {
          "category": "request_template",
          "description": "Default request body for the playground",
          "file_path": "../../docs/request-template.json",
          "is_active": true,
          "is_public": true,
          "mime_type": "json"
    }

  }
}
